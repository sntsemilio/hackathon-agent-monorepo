# ═══════════════════════════════════════════
# HAVI × HEY BANCO — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ═══════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────
# Elige uno. OpenAI es el default para demo local.
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=                 # opcional
GOOGLE_API_KEY=                    # opcional (Gemini)

# Modelo a usar (LiteLLM format)
LLM_MODEL=gpt-4o-mini              # default económico
# LLM_MODEL=gpt-4o                 # alternativa premium
# LLM_MODEL=claude-sonnet-4-6      # alternativa Anthropic
# LLM_MODEL=gemini/gemini-1.5-flash # alternativa Google

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                    # dejar vacío si no hay auth

# ── Backend ──────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true                # false en producción

# ── Analytics / Clustering ───────────────────────────────
ANALYTICS_MODELS_DIR=./app/analytics/models
FICHA_PREFIX=ficha:
FICHA_TTL_SECONDS=86400
MODELS_DIR=./backend/app/analytics/models

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=Havi × Hey Banco

# ── Admin / Observabilidad ───────────────────────────────
ADMIN_JWT_SECRET=cambia-esto-en-produccion
ADMIN_USERNAME=admin
ADMIN_PASSWORD=datathon2026

# ── RAG / Vector Store ───────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
REDIS_INDEX_NAME=havi_kb
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# ── API Config ───────────────────────────────────────────
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080
TESTING=false

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ADMIN_ROLE_NAME=admin
OLLAMA_API_BASE=http://localhost:11434

GUARDRAIL_MODEL=ollama_chat/qwen2.5:1.5b-instruct
SUMMARIZER_MODEL=ollama_chat/qwen2.5:1.5b-instruct
PROFILER_MODEL=ollama_chat/qwen2.5:1.5b-instruct
SUPERVISOR_ROUTER_MODEL=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_PROFILER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_PLANNER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_RESPONDER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_GUARDRAIL=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_SUMMARIZER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_TEMPERATURE=0
SECURITY_VIOLATION_MESSAGE=Security policy violation detected. The request was blocked by the guardrail.

REDIS_URL=redis://redis:6379/0
REDIS_INDEX_NAME=hackathon_docs
REDIS_PREFIX=doc:
REDIS_VECTOR_DIMS=1536
RATE_LIMIT_STORAGE_URL=redis://redis:6379/0
CHAT_RATE_LIMIT=20/minute
BUDGET_LIMIT_PER_WINDOW=20
BUDGET_WINDOW_SECONDS=60
CONVERSATIONAL_PROFILE_PREFIX=conv_profile:

ANALYTICS_MODELS_DIR=app/analytics/models

MCP_HOST=localhost
MCP_PORT=8765
MCP_CONNECT_TIMEOUT_SECONDS=5
MCP_GATEWAY_URL=http://localhost:8765
MCP_GATEWAY_TOKEN=demo-token

MAX_GLOBAL_ITERATIONS=5
RAG_DENSE_TOP_K=15
RAG_FINAL_TOP_K=3

# Observability
OTEL_ENABLED=true
OTEL_SERVICE_NAME=havi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OBS_HISTORY_LIMIT=200
OBS_SSE_TRACE_EVENTS=true

OLLAMA_MODEL=qwen2.5:1.5b-instruct

# WebSocket
WS_PROACTIVE_INTERVAL_SECONDS=30

# Feature flags
FEATURE_FLAGS_REDIS_KEY=feature_flags

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:3000

GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SERVICE_NAME=hackathon-agent-backend
