# Copia este archivo a `.env` y completa los valores
# cp .env.example .env

# ---------- Infra ----------
REDIS_URL=redis://localhost:6379
FICHA_PREFIX=ficha:
FICHA_TTL_SECONDS=0
MODELS_DIR=./backend/app/analytics/models

# ---------- LLMs (LiteLLM router) ----------
OLLAMA_API_BASE=http://localhost:11434
LITELLM_MODEL_PROFILER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_PLANNER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_RESPONDER=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_GUARDRAIL=ollama_chat/qwen2.5:1.5b-instruct
LITELLM_MODEL_SUMMARIZER=ollama_chat/qwen2.5:1.5b-instruct

# ---------- RAG ----------
REDIS_INDEX_NAME=havi_kb
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# ---------- API ----------
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO
